// test: @implements resolves generic template parameter on interface method
// feature: completion
// Adapted from phpactor generics/class_implements_single1.test
// expect: bazMethod(
---
<?php

/**
 * @template Y
 */
interface Second {
    /**
     * @return Y
     */
    public function boo();
}

class Baz {
    public function bazMethod(): void {}
}

/**
 * @implements Second<Baz>
 */
class Foo implements Second
{
    public function boo() {}
}

$foo = new Foo();
$foo->boo()-><>