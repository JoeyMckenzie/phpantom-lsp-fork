---
<?php

class IntWrapper {
    public function intValue(): int {}
}

class Foobar {
    /**
     * @return \Generator<IntWrapper>
     */
    public function gen(): \Generator
    {
    }
}

$foo = new Foobar();

foreach ($foo->gen() as $bar) {
    $bar-><>
}