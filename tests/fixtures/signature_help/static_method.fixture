// test: signature help on static method call shows parameters
// feature: signature_help
// Adapted from phpactor WorseSignatureHelperTest 'static method call'
// expect_sig_label: (string $foo, int $bar): mixed
// expect_sig_active: 0
// expect_sig_param: string $foo
// expect_sig_param: int $bar
---
<?php

class Foo {
    public static function hello(string $foo, int $bar) {}
}

Foo::hello(<>);