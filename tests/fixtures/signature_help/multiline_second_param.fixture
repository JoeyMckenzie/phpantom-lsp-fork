// test: signature help with 2nd parameter active on multiple lines
// feature: signature_help
// Adapted from phpactor WorseSignatureHelperTest 'function with parameters, 2nd active on multiple lines'
// expect_sig_label: (string $foo, int $bar): mixed
// expect_sig_active: 1
// expect_sig_param: string $foo
// expect_sig_param: int $bar
---
<?php

function hello(string $foo, int $bar) {}

hello(
    "hello",
    <>
);